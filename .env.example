# LueRevival configuration
# Copy this file to .env, then change every *_CHANGE_ME value before production.

NODE_ENV=production
PORT=3000
TRUST_PROXY=1
BASE_URL=https://lue.example.com
SITE_NAME=LueRevival
SITE_TAGLINE=Modern AlpacaBoards revival, old-board soul intact.

# Postgres. In Docker these match docker-compose.yml defaults.
POSTGRES_DB=luerevival
POSTGRES_USER=luerevival
POSTGRES_PASSWORD=POSTGRES_PASSWORD_CHANGE_ME
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Optional explicit override. Usually leave unset for Docker; app builds DATABASE_URL from POSTGRES_*.
# DATABASE_URL=postgres://luerevival:POSTGRES_PASSWORD_CHANGE_ME@db:5432/luerevival

# Sessions / CSRF / cookies. Generate with: openssl rand -base64 48
SESSION_SECRET=SESSION_SECRET_CHANGE_ME_48_BYTES_MIN
COOKIE_SECURE=true

# First admin seed. Only used when no users exist yet.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ADMIN_PASSWORD_CHANGE_ME_16_PLUS_CHARS

# Registration controls: open, invite, closed
REGISTRATION_MODE=invite
INVITES_ENABLED=true

# Upload handling
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=8

# Optional outbound email placeholders. Password reset / invite delivery logs locally unless SMTP is configured later.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=LueRevival <noreply@example.com>
