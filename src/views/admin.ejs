<%- include('partials/header', { title: 'Admin' }) %>
<h2>Admin</h2>
<p><a href="/admin/users">Users</a> | <a href="/admin/site">Site Options</a> | <a href="/admin/boards">Boards</a> | <a href="/admin/tags">Tags</a></p>
<table class="grid"><tr><th>Users</th><th>Topics</th><th>Messages</th><th>Links</th><th>Open Reports</th></tr><tr><td><%= stats.users %></td><td><%= stats.topics %></td><td><%= stats.messages %></td><td><%= stats.links %></td><td><%= stats.reports %></td></tr></table>
<h3>Audit log</h3>
<table class="grid"><tr><th>When</th><th>Actor</th><th>Action</th><th>Entity</th></tr><% audit.forEach(function(a){ %><tr><td><%= new Date(a.created_at).toLocaleString() %></td><td><%= a.username || 'system' %></td><td><%= a.action %></td><td><%= a.entity_type %>#<%= a.entity_id || '' %></td></tr><% }) %></table>
<%- include('partials/footer') %>
