<%- include('partials/header', { title: profile.username }) %>
<h1 class="eoti-title">User Information Page</h1>
<div class="subnav"><a href="/">Global (1)</a>: <a href="#">Private Messages (11)</a> | <a href="/source">Help</a></div>
<div class="sectionbar">Current Information for <%= profile.username %></div>
<table class="info-table">
  <tr><td>User Name</td><td><a href="/u/<%= encodeURIComponent(profile.username) %>"><%= profile.username %></a><% if (profile.staff_title) { %> (<%= profile.staff_title %>)<% } %></td></tr>
  <tr><td>User ID</td><td><%= profile.id %></td></tr>
  <tr><td>Administrator of</td><td><% adminTags.forEach(function(t){ %>[<a href="/admin/tags/<%= t.id %>/edit"><%= t.title %></a>] <% }) %><%= adminTags.length ? '' : '-' %></td></tr>
  <tr><td>Moderator of</td><td><% modTags.forEach(function(t){ %>[<a href="/admin/tags/<%= t.id %>/edit"><%= t.title %></a>] <% }) %><%= modTags.length ? '' : '-' %></td></tr>
  <tr><td>Tokens</td><td><%= profile.good_tokens + profile.bad_tokens %></td></tr>
  <tr><td>Good Tokens</td><td><%= profile.good_tokens %></td></tr>
  <tr><td>Bad Tokens</td><td><%= profile.bad_tokens %></td></tr>
  <tr><td>Account Created</td><td><%= new Date(profile.account_created).toLocaleDateString() %></td></tr>
  <tr><td>Last Active</td><td><%= profile.last_active ? new Date(profile.last_active).toLocaleDateString() : '-' %></td></tr>
  <tr><td>Signature</td><td><%= profile.signature || '' %></td></tr>
  <tr><td>Quote</td><td><%= profile.quote || '' %></td></tr>
  <% if (profile.email) { %><tr><td>Email Address</td><td><%= profile.email %></td></tr><% } %>
  <tr><td>Instant Messaging</td><td><%= profile.instant_messaging || '' %></td></tr>
  <tr><td>Picture</td><td><% if (profile.avatar_url) { %><img class="profile-picture" src="<%= profile.avatar_url %>" alt="<%= profile.username %> picture"><% } else { %><div class="missing-picture">No picture uploaded.</div><% } %></td></tr>
</table>
<% if (currentUser && currentUser.id === profile.id) { %><p><a href="/settings/profile">Edit your profile</a></p><% } %>
<div class="sectionbar">More Options</div>
<p><form class="inline" method="post" action="/u/<%= encodeURIComponent(profile.username) %>/token"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="link-button" name="kind" value="good">Give <%= profile.username %> A Good Token</button></form></p>
<p><form class="inline" method="post" action="/u/<%= encodeURIComponent(profile.username) %>/token"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="link-button" name="kind" value="bad">Give <%= profile.username %> A Bad Token</button></form></p>
<h2>Recent topics</h2>
<ul><% topics.forEach(function(t){ %><li><a href="/topics/<%= t.id %>"><%= t.title %></a></li><% }) %></ul>
<%- include('partials/footer') %>
