<%- include('partials/header', { title: 'Tags Admin' }) %>
<h1 class="eoti-title">Tag Administration</h1>
<table class="grid"><tr><th>Title</th><th>Description</th><th>Access</th><th>Participation</th><th>Special</th><th>Edit</th></tr><% tags.forEach(function(t){ %><tr><td><%= t.title %></td><td><%= t.description %></td><td><%= t.access %></td><td><%= t.participation %></td><td><%= t.special ? 'yes' : 'no' %></td><td><a href="/admin/tags/<%= t.id %>/edit">edit</a></td></tr><% }) %></table>
<h3>Add/update tag</h3>
<form method="post" action="/admin/tags"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input name="title" required> <input name="description" size="60"> <select name="access"><option>public</option><option>private</option><option>moderator</option></select> <select name="participation"><option>open</option><option>staff</option><option>owner</option></select> <label><input type="checkbox" name="permanent"> permanent</label> <label><input type="checkbox" name="inceptive"> inceptive</label> <label><input type="checkbox" name="special"> special</label> <button>save</button></form>
<%- include('partials/footer') %>
